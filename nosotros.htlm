<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Patagonia 360</title>

<script src="https://cdn.tailwindcss.com"></script>
<script type="module" src="https://ajax.googleapis.com/ajax/libs/model-viewer/3.4.0/model-viewer.min.js"></script>

<style>
body {
    background: linear-gradient(180deg, #0b1a2a, #020617);
    color: white;
    font-family: system-ui;
}

model-viewer {
    width: 100%;
    height: 100%;
    background: transparent;
}

.viewer {
    width: 100%;
    max-width: 900px;
    height: 420px;
    margin: auto;
    border-radius: 20px;
    overflow: hidden;
}

.btn {
    padding: 14px 28px;
    border-radius: 40px;
    font-weight: 600;
    transition: 0.3s;
}

.btn-main {
    background: linear-gradient(135deg, #10b981, #059669);
}

.btn-outline {
    border: 1px solid #10b981;
}

.btn:hover {
    transform: scale(1.05);
}
</style>
</head>

<body>

<!-- NAV -->
<div style="position:absolute; top:20px; right:30px;">
    <a href="index.html">Inicio</a> |
    <a href="resto.html">Restaurante</a> |
    <a href="museo.html">Museo</a> |
    <a href="nosotros/index.html">Nosotros</a>
</div>

<!-- HERO -->
<div style="text-align:center; padding-top:120px;">

<h1 style="font-size:48px;">Patagonia 360</h1>

<p style="opacity:0.7;">Estudio de Imágenes</p>

<p style="margin-top:20px;">
Explora experiencias 3D y realidad aumentada
</p>

<div style="margin-top:40px;">
    <a href="resto.html" class="btn btn-main">🍔 Ver Restaurante</a>
    <a href="museo.html" class="btn btn-outline">🏛 Ver Museo</a>
</div>

</div>

<!-- VISOR -->
<div style="margin-top:60px;">
    <div class="viewer">
        <model-viewer 
            src="burga.glb"
            ios-src="burga.usdz"
            ar
            camera-controls
            auto-rotate>
        </model-viewer>
    </div>
</div>

<!-- LINKS ENTRE EXPERIENCIAS -->
<div style="text-align:center; margin-top:60px;">

<p>También podés explorar:</p>

<div style="margin-top:20px;">
    <a href="resto.html">🍔 Restaurante</a> |
    <a href="museo.html">🏛 Museo</a> |
    <a href="nosotros/index.html">🔍 Nosotros</a>
</div>

</div>

</body>
</html>
